        </mxCell>
        <mxCell id="sNXBgWrCTaq7Ox4FmM2A-8" value="JD.com: Tolerance threshold set to&#xa;12% of total character count." style="whiteSpace=wrap;strokeWidth=2;" vertex="1" parent="1">
