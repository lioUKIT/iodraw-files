        <mxCell id="CsVSboKwtgPaQZPg8vhi-9" value="Study 2 (Section 3)&lt;br style=&quot;font-size: 15px;&quot;&gt;&lt;i style=&quot;font-size: 15px;&quot;&gt;Cross-cultural sentiment analysis&lt;/i&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;&lt;br style=&quot;font-size: 15px;&quot;&gt;1. Chinese and Italian e-commerce wine reviews&lt;br style=&quot;font-size: 15px;&quot;&gt;2. Transformer-based native-language models&lt;br style=&quot;font-size: 15px;&quot;&gt;3. Compares evaluative intensity. emotional magnitude and review focal points&lt;br style=&quot;font-size: 15px;&quot;&gt;4. Reveals differences in emotional expression across cultural and market contexts&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Times New Roman;fontSize=15;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="190" y="160" width="150" height="300" as="geometry" />
        </mxCell>
        <mxCell id="CsVSboKwtgPaQZPg8vhi-10" value="Study 3 (Section 4)&lt;div style=&quot;font-size: 15px;&quot;&gt;&lt;i style=&quot;font-size: 15px;&quot;&gt;Psychological consumer profiling&lt;/i&gt;&lt;br style=&quot;font-size: 15px;&quot;&gt;&lt;br style=&quot;font-size: 15px;&quot;&gt;1. Unsupervised machine learning&lt;br style=&quot;font-size: 15px;&quot;&gt;2. Features: review length, star ratings, emotional expressions&lt;br style=&quot;font-size: 15px;&quot;&gt;3. Identifies latent psychological structures&lt;br style=&quot;font-size: 15px;&quot;&gt;4. Explains behavioral heterogeneity in digital retail&lt;br style=&quot;font-size: 15px;&quot;&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;&lt;br style=&quot;font-size: 15px;&quot;&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Times New Roman;fontSize=15;align=left;verticalAlign=top;fillColor=#f9f7ed;strokeColor=#36393d;" vertex="1" parent="1">
          <mxGeometry x="370" y="160" width="150" height="300" as="geometry" />
        </mxCell>
        <mxCell id="CsVSboKwtgPaQZPg8vhi-11" value="Study 4 (Section 5)&lt;br style=&quot;font-size: 15px;&quot;&gt;&lt;i style=&quot;font-size: 15px;&quot;&gt;Product-attribute evaluation&lt;/i&gt;&lt;br style=&quot;font-size: 15px;&quot;&gt;&lt;br style=&quot;font-size: 15px;&quot;&gt;1. Analyzes price, origin and product category&lt;br style=&quot;font-size: 15px;&quot;&gt;2. Uses interaction effect models&lt;br style=&quot;font-size: 15px;&quot;&gt;3. Examines heterogeneous effects of consumer profiles and product attributes&lt;br style=&quot;font-size: 15px;&quot;&gt;4. Uncovers decision-making mechanisms behind evaluative behaviors" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Times New Roman;fontSize=15;align=left;verticalAlign=top;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
