        <mxCell id="CsVSboKwtgPaQZPg8vhi-8" value="Study 1 (Section 2)&lt;br style=&quot;font-size: 15px;&quot;&gt;&lt;i style=&quot;font-size: 15px;&quot;&gt;Systematic literature review&lt;/i&gt;&lt;br style=&quot;font-size: 15px;&quot;&gt;&lt;br style=&quot;font-size: 15px;&quot;&gt;1. Big data in consumer behavior research&lt;div style=&quot;font-size: 15px;&quot;&gt;2. Summarizes data sources, methods and research questions&lt;br style=&quot;font-size: 15px;&quot;&gt;3. Identifies gaps in cross-cultural analysis, machine learning and theory integration&lt;br style=&quot;font-size: 15px;&quot;&gt;4. Builds the theoretical and methodological foundation&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Times New Roman;fontSize=15;align=left;verticalAlign=top;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="10" y="160" width="150" height="300" as="geometry" />
