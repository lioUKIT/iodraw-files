        </mxCell>
        <mxCell id="K6FOoUI3Ku2R6CiMHFNw-8" value="JD.com: Tolerance threshold set to&#xa;12% of total character count." style="whiteSpace=wrap;strokeWidth=2;" vertex="1" parent="1">
